# Enterprise DevEx Orchestrator — Environment Configuration
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   copy .env.example .env     (Windows)
#   cp .env.example .env       (macOS/Linux)
#
# IMPORTANT: Never commit .env to source control.
#
# NOTE: The orchestrator defaults to GitHub Copilot SDK when no explicit
# provider is configured. No additional setup is needed in Copilot-enabled
# environments. Set LLM_PROVIDER to switch to another backend.

# ── LLM Provider (default: copilot_sdk) ──────────────────────────────
# Supported: copilot_sdk, azure_openai, openai, anthropic, template-only
# If not set, auto-detects from available credentials or defaults to copilot_sdk
LLM_PROVIDER=copilot_sdk

# ── LLM Model (optional — provider-specific default used if not set) ─
# copilot_sdk: gpt-4o, gpt-4o-mini, gpt-4-turbo
# azure_openai: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, gpt-35-turbo
# openai: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, o1, o1-mini, o3-mini
# anthropic: claude-opus-4-20250514, claude-sonnet-4-20250514, claude-sonnet-3-5-20241022
LLM_MODEL=

# ── GitHub Copilot SDK (default provider) ────────────────────────────
# Obtain from https://github.com/settings/copilot
# Auto-detected when GITHUB_TOKEN is set
GITHUB_TOKEN=

# ── Azure OpenAI (optional — alternative provider) ──────────────────
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── OpenAI (optional — alternative provider) ────────────────────────
OPENAI_API_KEY=
OPENAI_ORG_ID=

# ── Anthropic / Claude (optional — alternative provider) ────────────
ANTHROPIC_API_KEY=

# ── Azure Configuration (required only for deployment) ───────────────
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=rg-enterprise-devex-orchestrator-dev
AZURE_LOCATION=eastus2

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
